<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Groupe Utilisateur Restaurant -->
        <record id="group_restaurant_user" model="res.groups">
            <field name="name">Utilisateur Restaurant</field>
            <field name="comment">Accès en lecture et création des données restaurant</field>
        </record>

        <!-- Groupe Manager Restaurant -->
        <record id="group_restaurant_manager" model="res.groups">
            <field name="name">Manager Restaurant</field>
            <field name="comment">Accès complet aux données restaurant</field>
            <field name="implied_ids" eval="[(4, ref('gestion_restaurant.group_restaurant_user'))]"/>
        </record>

    </data>
</odoo>
