<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <template id="report_commande_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2>Commande : <t t-esc="doc.name"/></h2>
                            <table class="table table-bordered">
                                <tr>
                                    <td><strong>Table</strong></td>
                                    <td><t t-esc="doc.table_id.name"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Serveur</strong></td>
                                    <td><t t-esc="doc.serveur_id.name or 'Non assigné'"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Date</strong></td>
                                    <td><span t-field="doc.date_commande" t-options='{"widget": "date"}'/></td>
                                </tr>
                                <tr>
                                    <td><strong>État</strong></td>
                                    <td>
                                        <t t-if="doc.etat == 'en_attente'">En attente</t>
                                        <t t-elif="doc.etat == 'en_preparation'">En préparation</t>
                                        <t t-elif="doc.etat == 'servie'">Servie</t>
                                        <t t-elif="doc.etat == 'payee'">Payée</t>
                                    </td>
                                </tr>
                            </table>

                            <h3 style="margin-top: 20px;">Lignes de commande</h3>
                            <table class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Plat</th>
                                        <th>Catégorie</th>
                                        <th>Quantité</th>
                                        <th>Prix unitaire</th>
                                        <th>Sous-total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.ligne_ids" t-as="ligne">
                                        <tr>
                                            <td><t t-esc="ligne.plat_id.name"/></td>
                                            <td><t t-esc="dict(ligne.plat_id.fields_get(['categorie'])['categorie']['selection']).get(ligne.plat_id.categorie, '')"/></td>
                                            <td><t t-esc="ligne.quantite"/></td>
                                            <td><t t-esc="'%.2f' % ligne.prix_unitaire"/> MAD</td>
                                            <td><t t-esc="'%.2f' % ligne.sous_total"/> MAD</td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4" style="text-align: right;"><strong>Total</strong></td>
                                        <td><strong><t t-esc="'%.2f' % doc.montant_total"/> MAD</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_report_commande" model="ir.actions.report">
            <field name="name">Commande Restaurant</field>
            <field name="model">gestion.commande</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">gestion_restaurant.report_commande_template</field>
            <field name="report_file">gestion_restaurant.report_commande_template</field>
            <field name="print_report_name">'Commande_%s' % object.name</field>
            <field name="binding_model_id" ref="model_gestion_commande"/>
            <field name="binding_type">report</field>
        </record>

    </data>
</odoo>
