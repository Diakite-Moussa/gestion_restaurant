<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ==================== TABLES ==================== -->
        <record id="table_form_view" model="ir.ui.view">
            <field name="name">gestion.table.form</field>
            <field name="model">gestion.table</field>
            <field name="arch" type="xml">
                <form string="Table">
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="capacite"/>
                            <field name="etat"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="table_tree_view" model="ir.ui.view">
            <field name="name">gestion.table.list</field>
            <field name="model">gestion.table</field>
            <field name="arch" type="xml">
                <list string="Tables">
                    <field name="name"/>
                    <field name="capacite"/>
                    <field name="etat"/>
                </list>
            </field>
        </record>

        <record id="table_kanban_view" model="ir.ui.view">
            <field name="name">gestion.table.kanban</field>
            <field name="model">gestion.table</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="name"/>
                    <field name="capacite"/>
                    <field name="etat"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card">
                                <strong><field name="name"/></strong>
                                <p>Capacité : <field name="capacite"/></p>
                                <p>État : <field name="etat"/></p>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="table_action" model="ir.actions.act_window">
            <field name="name">Tables</field>
            <field name="res_model">gestion.table</field>
            <field name="view_mode">list,form,kanban</field>
        </record>

        <!-- ==================== PLATS ==================== -->
        <record id="plat_form_view" model="ir.ui.view">
            <field name="name">gestion.plat.form</field>
            <field name="model">gestion.plat</field>
            <field name="arch" type="xml">
                <form string="Plat">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="prix"/>
                            <field name="categorie"/>
                            <field name="disponible"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="plat_tree_view" model="ir.ui.view">
            <field name="name">gestion.plat.list</field>
            <field name="model">gestion.plat</field>
            <field name="arch" type="xml">
                <list string="Plats">
                    <field name="name"/>
                    <field name="categorie"/>
                    <field name="prix"/>
                    <field name="disponible"/>
                </list>
            </field>
        </record>

        <record id="plat_kanban_view" model="ir.ui.view">
            <field name="name">gestion.plat.kanban</field>
            <field name="model">gestion.plat</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="name"/>
                    <field name="categorie"/>
                    <field name="prix"/>
                    <field name="disponible"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card">
                                <strong><field name="name"/></strong>
                                <p>Catégorie : <field name="categorie"/></p>
                                <p>Prix : <field name="prix"/> MAD</p>
                                <p>Disponible : <field name="disponible"/></p>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="plat_action" model="ir.actions.act_window">
            <field name="name">Plats</field>
            <field name="res_model">gestion.plat</field>
            <field name="view_mode">list,form,kanban</field>
        </record>

        <!-- ==================== RESERVATIONS ==================== -->
        <record id="reservation_form_view" model="ir.ui.view">
            <field name="name">gestion.reservation.form</field>
            <field name="model">gestion.reservation</field>
            <field name="arch" type="xml">
                <form string="Réservation">
                    <header>
                        <button name="action_confirmer" string="Confirmer" type="object"
                            invisible="etat not in ('en_attente', 'annulee')" class="btn-primary"/>
                        <button name="action_annuler" string="Annuler" type="object"
                            invisible="etat != 'confirmee'" class="btn-danger"/>
                        <field name="etat" widget="statusbar"
                            statusbar_visible="en_attente,confirmee,annulee"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="client_name"/>
                                <field name="table_id"/>
                            </group>
                            <group>
                                <field name="date_reservation"/>
                                <field name="nombre_personnes"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="reservation_tree_view" model="ir.ui.view">
            <field name="name">gestion.reservation.list</field>
            <field name="model">gestion.reservation</field>
            <field name="arch" type="xml">
                <list string="Réservations">
                    <field name="name"/>
                    <field name="client_name"/>
                    <field name="table_id"/>
                    <field name="date_reservation"/>
                    <field name="nombre_personnes"/>
                    <field name="etat"/>
                </list>
            </field>
        </record>

        <record id="reservation_kanban_view" model="ir.ui.view">
            <field name="name">gestion.reservation.kanban</field>
            <field name="model">gestion.reservation</field>
            <field name="arch" type="xml">
                <kanban default_group_by="etat">
                    <field name="name"/>
                    <field name="client_name"/>
                    <field name="table_id"/>
                    <field name="etat"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card">
                                <strong><field name="name"/></strong>
                                <p>Client : <field name="client_name"/></p>
                                <p>Table : <field name="table_id"/></p>
                                <p>Date : <field name="date_reservation"/></p>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="reservation_action" model="ir.actions.act_window">
            <field name="name">Réservations</field>
            <field name="res_model">gestion.reservation</field>
            <field name="view_mode">list,form,kanban</field>
        </record>

        <!-- ==================== COMMANDES ==================== -->
        <record id="commande_form_view" model="ir.ui.view">
            <field name="name">gestion.commande.form</field>
            <field name="model">gestion.commande</field>
            <field name="arch" type="xml">
                <form string="Commande">
                    <header>
                        <button name="action_en_preparation" string="En préparation" type="object"
                            invisible="etat != 'en_attente'" class="btn-primary"/>
                        <button name="action_servie" string="Servie" type="object"
                            invisible="etat != 'en_preparation'" class="btn-primary"/>
                        <button name="action_payee" string="Payée" type="object"
                            invisible="etat != 'servie'" class="btn-primary"/>
                        <field name="etat" widget="statusbar"
                            statusbar_visible="en_attente,en_preparation,servie,payee"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="table_id"/>
                                <field name="serveur_id"/>
                            </group>
                            <group>
                                <field name="date_commande"/>
                                <field name="montant_total" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lignes de commande">
                                <field name="ligne_ids">
                                    <list editable="bottom">
                                        <field name="plat_id"/>
                                        <field name="quantite"/>
                                        <field name="prix_unitaire" readonly="1"/>
                                        <field name="sous_total" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="commande_tree_view" model="ir.ui.view">
            <field name="name">gestion.commande.list</field>
            <field name="model">gestion.commande</field>
            <field name="arch" type="xml">
                <list string="Commandes">
                    <field name="name"/>
                    <field name="table_id"/>
                    <field name="serveur_id"/>
                    <field name="date_commande"/>
                    <field name="etat"/>
                    <field name="montant_total"/>
                </list>
            </field>
        </record>

        <record id="commande_kanban_view" model="ir.ui.view">
            <field name="name">gestion.commande.kanban</field>
            <field name="model">gestion.commande</field>
            <field name="arch" type="xml">
                <kanban default_group_by="etat">
                    <field name="name"/>
                    <field name="table_id"/>
                    <field name="etat"/>
                    <field name="montant_total"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card">
                                <strong><field name="name"/></strong>
                                <p>Table : <field name="table_id"/></p>
                                <p>Total : <field name="montant_total"/> MAD</p>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="commande_graph_view" model="ir.ui.view">
            <field name="name">gestion.commande.graph</field>
            <field name="model">gestion.commande</field>
            <field name="arch" type="xml">
                <graph string="Statistiques commandes">
                    <field name="etat"/>
                    <field name="montant_total" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="commande_pivot_view" model="ir.ui.view">
            <field name="name">gestion.commande.pivot</field>
            <field name="model">gestion.commande</field>
            <field name="arch" type="xml">
                <pivot string="Analyse commandes">
                    <field name="etat" type="row"/>
                    <field name="montant_total" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="commande_action" model="ir.actions.act_window">
            <field name="name">Commandes</field>
            <field name="res_model">gestion.commande</field>
            <field name="view_mode">list,form,kanban,graph,pivot</field>
        </record>

        <!-- ==================== MENUS ==================== -->
        <menuitem id="menu_gestion_restaurant" name="Gestion Restaurant" sequence="10"/>
        <menuitem id="menu_tables" name="Tables" parent="menu_gestion_restaurant" action="table_action" sequence="10"/>
        <menuitem id="menu_reservations" name="Réservations" parent="menu_gestion_restaurant" action="reservation_action" sequence="20"/>
        <menuitem id="menu_commandes" name="Commandes" parent="menu_gestion_restaurant" action="commande_action" sequence="30"/>
        <menuitem id="menu_configuration" name="Configuration" parent="menu_gestion_restaurant" sequence="100"/>
        <menuitem id="menu_plats" name="Plats" parent="menu_configuration" action="plat_action" sequence="10"/>

    </data>
</odoo>
