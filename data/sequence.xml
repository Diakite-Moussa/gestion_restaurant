<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Séquence automatique pour les tables -->
        <record id="seq_gestion_table" model="ir.sequence">
            <field name="name">Séquence Table Restaurant</field>
            <field name="code">gestion.table</field>
            <field name="prefix">Table </field>
            <field name="padding">0</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Séquence automatique pour les commandes -->
        <record id="seq_gestion_commande" model="ir.sequence">
            <field name="name">Séquence Commande Restaurant</field>
            <field name="code">gestion.commande</field>
            <field name="prefix">CMD</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Séquence automatique pour les réservations -->
        <record id="seq_gestion_reservation" model="ir.sequence">
            <field name="name">Séquence Réservation Restaurant</field>
            <field name="code">gestion.reservation</field>
            <field name="prefix">RES</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
